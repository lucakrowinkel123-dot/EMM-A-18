// Carrier script: dock pose broadcaster + miner-style movement/nav controls.
//
// Commands:
// Nav;GPS:Name:X:Y:Z:|Ux,Uy,Uz,Fx,Fy,Fz
// Nav;GPS:Name:X:Y:Z:|Faceup,Faceforward
// start / stop / clear / dumpgps

string carrierConnectorName = "EMM-A Ca Connector";
string carrierRemoteName = "EMM-A Ca Remote Control";
string dockBroadcastTag = "EMM_A_DOCK_POSE";
double broadcastForwardOffset = 1.25;
string pathTimerTag = "Path";

// Movement settings (ported from miner behavior)
double maxSpeed = 25;
double arrivalTolerance = 2.5;
double orientationToleranceDeg = 1.0;
UpdateFrequency tickSpeed = UpdateFrequency.Update1;

IMyShipConnector carrierConnector;
IMyShipController rc;
GyroControl gyros;
ThrusterControl thrust;
List<IMyGyro> allGyros = new List<IMyGyro>();
List<IMyThrust> allThrusters = new List<IMyThrust>();

Vector3D targetPosition = Vector3D.Zero;
bool hasTarget = false;
bool autopilotEnabled = false;
Vector3D desiredForward = Vector3D.Zero;
Vector3D desiredUp = Vector3D.Zero;
bool pathMode = false;
bool pathPaused = false;
List<string> pathRecords = new List<string>();
int pathIndex = 0;
IMyTimerBlock _cachedPathTimer;

public Program()
{
    carrierConnector = GetBlock<IMyShipConnector>(carrierConnectorName, true);

    rc = GetBlock<IMyShipController>(carrierRemoteName, true);
    if (rc == null)
        rc = GetBlock<IMyRemoteControl>(true);
    if (rc == null)
        rc = GetBlock<IMyCockpit>(true);

    if (rc == null)
        throw new Exception("No remote/cockpit found for movement control.");

    allGyros = GetBlocks<IMyGyro>();
    allThrusters = GetBlocks<IMyThrust>();
    gyros = new GyroControl((IMyCubeBlock)rc, tickSpeed, allGyros);
    thrust = new ThrusterControl(rc, tickSpeed, allThrusters);

    Runtime.UpdateFrequency = tickSpeed;
}

public void Main(string argument, UpdateType updateSource)
{
    if (!string.IsNullOrWhiteSpace(argument))
        RemoteCommand(argument);

    BroadcastDockPose();

    if (autopilotEnabled && hasTarget)
        Move();
    else
        ResetMovement();

    UpdatePathRunner();

    Echo($"Dock pose broadcast: {dockBroadcastTag}");
    Echo(carrierConnector == null ? "Connector: <missing>" : "Connector: " + carrierConnector.CustomName);
    Echo($"Nav: {(autopilotEnabled ? "ON" : "OFF")}");
    Echo(hasTarget ? $"Target: {targetPosition.ToString("0.00")}" : "Target: <none>");
    Echo($"Arrival tolerance: {arrivalTolerance:0.00} m");
    Echo($"Orientation tolerance: {orientationToleranceDeg:0.00} deg");
    if (pathMode)
        Echo($"Path: {Math.Min(pathIndex + 1, pathRecords.Count)}/{pathRecords.Count}" + (pathPaused ? " (paused)" : ""));
}

void BroadcastDockPose()
{
    if (carrierConnector == null)
        carrierConnector = GetBlock<IMyShipConnector>(carrierConnectorName, true);

    if (carrierConnector == null)
    {
        Echo("Carrier connector not found: " + carrierConnectorName);
        return;
    }

    MatrixD m = carrierConnector.WorldMatrix;
    Vector3D pos = carrierConnector.GetPosition();
    Vector3D f = Vector3D.Normalize(m.Forward);
    Vector3D u = Vector3D.Normalize(m.Up);
    pos += f * broadcastForwardOffset;

    string payload = ToCsv(pos) + "|" + ToCsv(f) + "|" + ToCsv(u);
    IGC.SendBroadcastMessage(dockBroadcastTag, payload);
}

void Move ()
{
    Vector3D position = rc.GetPosition();
    Vector3D toTarget = targetPosition - position;
    double tolerance = Math.Max(0.05, arrivalTolerance);

    Vector3D forward = desiredForward;
    if (forward == Vector3D.Zero && toTarget.LengthSquared() > 0.001)
        forward = Vector3D.Normalize(toTarget);

    Vector3D up = desiredUp;
    if (up == Vector3D.Zero)
    {
        Vector3D gravity = rc.GetNaturalGravity();
        if (gravity.LengthSquared() > 0.001)
            up = Vector3D.Normalize(-gravity);
        else
            up = rc.WorldMatrix.Up;
    }

    gyros.FaceVectors(forward, up);

    bool atPosition = toTarget.LengthSquared() < tolerance * tolerance;
    bool aligned = IsOrientationAligned(forward, up, orientationToleranceDeg);
    if (atPosition)
    {
        thrust.Reset();
        if (aligned)
            gyros.Reset();
        return;
    }

    thrust.ApplyAccel(thrust.ControlPosition(targetPosition, Vector3D.Zero, maxSpeed));
}

bool IsOrientationAligned(Vector3D forward, Vector3D up, double toleranceDeg)
{
    double minDot = Math.Cos(Math.Max(0.1, toleranceDeg) * Math.PI / 180.0);
    MatrixD wm = rc.WorldMatrix;
    if (forward.LengthSquared() > 0.001 && Vector3D.Dot(wm.Forward, Vector3D.Normalize(forward)) < minDot)
        return false;
    if (up.LengthSquared() > 0.001 && Vector3D.Dot(wm.Up, Vector3D.Normalize(up)) < minDot)
        return false;
    return true;
}

void ResetMovement()
{
    gyros.Reset();
    thrust.Reset();
}

void RemoteCommand (string command)
{
    if (command == null)
        return;

    string trimmed = command.Trim();
    if (trimmed.Length == 0)
        return;

    if (trimmed.Equals("stop", StringComparison.OrdinalIgnoreCase))
    {
        autopilotEnabled = false;
        ResetMovement();
        Echo("Autopilot stopped.");
        return;
    }

    if (trimmed.Equals("start", StringComparison.OrdinalIgnoreCase))
    {
        if (!hasTarget)
        {
            Echo("No target. Use Nav;GPS:... first.");
            return;
        }
        autopilotEnabled = true;
        Echo("Autopilot started.");
        return;
    }

    if (trimmed.Equals("clear", StringComparison.OrdinalIgnoreCase))
    {
        hasTarget = false;
        autopilotEnabled = false;
        targetPosition = Vector3D.Zero;
        desiredForward = Vector3D.Zero;
        desiredUp = Vector3D.Zero;
        ResetMovement();
        Echo("Target cleared.");
        return;
    }

    if (trimmed.Equals("dumpgps", StringComparison.OrdinalIgnoreCase))
    {
        DumpGps();
        return;
    }

    switch (trimmed.ToLower())
    {
        case "pathstart":
            StartPathFromTimer();
            return;
        case "pathpause":
            if (!pathMode)
            {
                Echo("Path mode is not active.");
                return;
            }
            pathPaused = true;
            autopilotEnabled = false;
            ResetMovement();
            Echo("Path paused.");
            return;
        case "pathcontinue":
            if (!pathMode)
            {
                Echo("Path mode is not active.");
                return;
            }
            pathPaused = false;
            Echo("Path resumed.");
            return;
        case "pathstop":
            pathMode = false;
            pathPaused = false;
            pathRecords.Clear();
            pathIndex = 0;
            autopilotEnabled = false;
            hasTarget = false;
            ResetMovement();
            Echo("Path stopped.");
            return;
    }

    if (trimmed.StartsWith("Nav;", StringComparison.OrdinalIgnoreCase))
    {
        if (TryParseNavCommand(trimmed, out targetPosition, out desiredUp, out desiredForward))
        {
            hasTarget = true;
            autopilotEnabled = true;
            Echo("Nav target set.");
        }
        else
        {
            Echo("Invalid Nav command.");
        }
        return;
    }

    Echo("Unknown command.");
}

bool TryParseNavCommand(string command, out Vector3D gps, out Vector3D up, out Vector3D forward)
{
    gps = Vector3D.Zero;
    up = Vector3D.Zero;
    forward = Vector3D.Zero;

    string[] parts = command.Split(';');
    if (parts.Length < 2)
        return false;

    string gpsPart = parts[1].Trim();
    string orientPart = parts.Length >= 3 ? parts[2].Trim() : "";

    if (!TryParseGps(gpsPart, out gps))
        return false;

    if (orientPart.StartsWith("GPS:", StringComparison.OrdinalIgnoreCase))
    {
        int pipe = orientPart.IndexOf('|');
        if (pipe >= 0)
            orientPart = orientPart.Substring(pipe + 1);
    }

    if (string.IsNullOrWhiteSpace(orientPart))
        return true;

    string[] modes = orientPart.Split(',');
    if (modes.Length == 6)
    {
        double ux, uy, uz, fx, fy, fz;
        if (double.TryParse(modes[0].Trim(), out ux) &&
            double.TryParse(modes[1].Trim(), out uy) &&
            double.TryParse(modes[2].Trim(), out uz) &&
            double.TryParse(modes[3].Trim(), out fx) &&
            double.TryParse(modes[4].Trim(), out fy) &&
            double.TryParse(modes[5].Trim(), out fz))
        {
            up = new Vector3D(ux, uy, uz);
            forward = new Vector3D(fx, fy, fz);
            if (up.LengthSquared() > 0.001)
                up = Vector3D.Normalize(up);
            if (forward.LengthSquared() > 0.001)
                forward = Vector3D.Normalize(forward);
            return true;
        }
        return false;
    }

    Vector3D toTarget = gps - rc.GetPosition();
    foreach (string rawMode in modes)
    {
        string mode = rawMode.Trim().ToLower();
        if (mode == "faceforward")
        {
            if (toTarget.LengthSquared() > 0.001)
                forward = Vector3D.Normalize(toTarget);
        }
        else if (mode == "faceup")
        {
            Vector3D gravity = rc.GetNaturalGravity();
            if (gravity.LengthSquared() > 0.001)
                up = Vector3D.Normalize(-gravity);
            else
                up = rc.WorldMatrix.Up;
        }
    }

    return true;
}

bool TryParseGps(string token, out Vector3D v)
{
    v = Vector3D.Zero;
    string t = token.Trim();
    if (!t.StartsWith("GPS:", StringComparison.OrdinalIgnoreCase))
        return false;

    string[] parts = t.Split(':');
    if (parts.Length < 5)
        return false;

    double x, y, z;
    if (!double.TryParse(parts[2], out x) || !double.TryParse(parts[3], out y) || !double.TryParse(parts[4], out z))
        return false;

    v = new Vector3D(x, y, z);
    return true;
}

void DumpGps()
{
    if (rc == null)
        return;

    Vector3D pos = rc.GetPosition();
    Vector3D up = rc.WorldMatrix.Up;
    Vector3D forward = rc.WorldMatrix.Forward;
    string line = "GPS:Snap:" + pos.X.ToString("0.00") + ":" + pos.Y.ToString("0.00") + ":" + pos.Z.ToString("0.00") + ":|"
                + up.X.ToString("0.0000") + "," + up.Y.ToString("0.0000") + "," + up.Z.ToString("0.0000") + ","
                + forward.X.ToString("0.0000") + "," + forward.Y.ToString("0.0000") + "," + forward.Z.ToString("0.0000");
    if (string.IsNullOrWhiteSpace(Me.CustomData))
        Me.CustomData = line;
    else
        Me.CustomData += "\n" + line;
    Echo("Dumped GPS/orientation to Custom Data.");
}

void UpdatePathRunner()
{
    if (!pathMode || pathRecords.Count == 0)
        return;
    if (pathPaused)
        return;

    if (autopilotEnabled && hasTarget)
    {
        if (IsAtTargetPose(targetPosition, desiredForward, desiredUp))
        {
            autopilotEnabled = false;
            hasTarget = false;
        }
        return;
    }

    StartNextPathRecord();
}

bool IsAtTargetPosition(Vector3D target)
{
    double tolerance = Math.Max(0.05, arrivalTolerance);
    return Vector3D.DistanceSquared(rc.GetPosition(), target) < tolerance * tolerance;
}

bool IsAtTargetPose(Vector3D target, Vector3D forward, Vector3D up)
{
    return IsAtTargetPosition(target) && IsOrientationAligned(forward, up, orientationToleranceDeg);
}

void StartPathFromTimer()
{
    List<string> loaded;
    string timerName;
    if (!TryLoadPathRecordsFromTimer(out loaded, out timerName))
    {
        Echo($"Unable to load path records from timer tag '{pathTimerTag}'.");
        return;
    }

    pathRecords = loaded;
    pathIndex = 0;
    pathMode = true;
    pathPaused = false;
    Echo($"Loaded {pathRecords.Count} path records from timer '{timerName}'.");
    StartNextPathRecord();
}

void StartNextPathRecord()
{
    while (pathMode && pathIndex < pathRecords.Count)
    {
        string record = pathRecords[pathIndex];
        pathIndex++;
        if (ExecutePathRecord(record))
            return;
        Echo($"Skipping invalid path record #{pathIndex}.");
    }

    if (pathMode && pathIndex >= pathRecords.Count)
    {
        pathMode = false;
        Echo("Path execution complete.");
    }
}

bool ExecutePathRecord(string rawRecord)
{
    if (string.IsNullOrWhiteSpace(rawRecord))
        return false;

    string record = rawRecord.Trim();
    if (record.StartsWith("\"") && record.EndsWith("\"") && record.Length >= 2)
        record = record.Substring(1, record.Length - 2).Trim();
    if (string.IsNullOrWhiteSpace(record))
        return false;

    string navCmd = null;
    if (record.StartsWith("Nav;", StringComparison.OrdinalIgnoreCase))
        navCmd = record;
    else if (record.StartsWith("GPS:", StringComparison.OrdinalIgnoreCase))
        navCmd = "Nav;" + record;

    if (navCmd == null)
        return false;

    Vector3D gps, up, forward;
    if (!TryParseNavCommand(navCmd, out gps, out up, out forward))
        return false;

    targetPosition = gps;
    desiredForward = forward;
    desiredUp = up;
    hasTarget = true;
    autopilotEnabled = true;
    return true;
}

bool TryLoadPathRecordsFromTimer(out List<string> records, out string timerName)
{
    records = new List<string>();
    timerName = "";

    IMyTimerBlock timer = FindPathTimer();
    if (timer == null)
        return false;

    timerName = timer.CustomName;
    string data = timer.CustomData ?? "";
    string[] lines = data.Split(new [] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries);
    foreach (string line in lines)
    {
        string rec = line.Trim();
        if (string.IsNullOrWhiteSpace(rec))
            continue;
        if (rec.StartsWith("\"") && rec.EndsWith("\"") && rec.Length >= 2)
            rec = rec.Substring(1, rec.Length - 2).Trim();
        if (string.IsNullOrWhiteSpace(rec))
            continue;
        records.Add(rec);
    }

    return records.Count > 0;
}

IMyTimerBlock FindPathTimer()
{
    if (_cachedPathTimer != null &&
        _cachedPathTimer.CustomName.IndexOf(pathTimerTag, StringComparison.OrdinalIgnoreCase) >= 0)
        return _cachedPathTimer;
    foreach (var t in GetBlocks<IMyTimerBlock>())
        if (t != null && !string.IsNullOrWhiteSpace(t.CustomName) &&
            t.CustomName.IndexOf(pathTimerTag, StringComparison.OrdinalIgnoreCase) >= 0)
        {
            _cachedPathTimer = t;
            return t;
        }
    _cachedPathTimer = null;
    return null;
}

string ToCsv(Vector3D v)
{
    return v.X.ToString("0.000") + "," + v.Y.ToString("0.000") + "," + v.Z.ToString("0.000");
}

T GetBlock<T> (string name, bool useSubgrids = false) where T : class, IMyTerminalBlock
{
    if (useSubgrids)
        return GridTerminalSystem.GetBlockWithName(name) as T;
    foreach (T block in GetBlocks<T>(false))
        if (block.CustomName == name)
            return block;
    return null;
}

T GetBlock<T> (bool useSubgrids = false) where T : class, IMyTerminalBlock
{
    List<T> blocks = GetBlocks<T>(useSubgrids);
    return blocks.FirstOrDefault();
}

List<T> GetBlocks<T> (bool useSubgrids = false) where T : class, IMyTerminalBlock
{
    List<T> blocks = new List<T>();
    if (useSubgrids)
        GridTerminalSystem.GetBlocksOfType(blocks);
    else
        GridTerminalSystem.GetBlocksOfType(blocks, b => b.CubeGrid.EntityId == Me.CubeGrid.EntityId);
    return blocks;
}

const double gyroP = 10;
const double gyroI = 0;
const double gyroD = 5;
const double gyroMax = 1000;
const double gyroErrorDeadbandRad = 0.003;
const double gyroOutputDeadband = 0.002;
const double gyroFineDampRangeRad = 0.12;
const double gyroRateLimit = 0.35;

class GyroControl
{
    private List<IMyGyro> gyros;
    IMyCubeBlock rc;
    VectorPID anglePID;

    public GyroControl (IMyCubeBlock rc, UpdateFrequency tickSpeed, List<IMyGyro> gyros)
    {
        if (rc == null)
            throw new Exception("Reference block null.");

        this.rc = rc;
        this.gyros = gyros;

        double factor = 1;
        if (tickSpeed == UpdateFrequency.Update10)
            factor = 10;
        else if (tickSpeed == UpdateFrequency.Update100)
            factor = 100;
        double secondsPerTick = (1.0 / 60) * factor;
        anglePID = new VectorPID(gyroP / factor, gyroI / factor, gyroD / factor, -gyroMax, gyroMax, secondsPerTick);

        Reset();
    }

    public void Reset ()
    {
        for (int i = 0; i < gyros.Count; i++)
        {
            IMyGyro g = gyros [i];
            if (g == null)
            {
                gyros.RemoveAtFast(i);
                continue;
            }
            g.GyroOverride = false;
        }
        anglePID.Reset();
    }

    Vector3D GetAngles (MatrixD current, Vector3D forward, Vector3D up)
    {
        Vector3D error = new Vector3D();

        if (forward != Vector3D.Zero)
        {
            Quaternion quat = Quaternion.CreateFromForwardUp(current.Forward, current.Up);
            Quaternion invQuat = Quaternion.Inverse(quat);
            Vector3D RCReferenceFrameVector = Vector3D.Transform(forward, invQuat);
            Vector3D.GetAzimuthAndElevation(RCReferenceFrameVector, out error.Y, out error.X);
        }

        if (up != Vector3D.Zero)
        {
            Vector3D temp = Vector3D.Normalize(VectorRejection(up, current.Forward));
            double dot = MathHelper.Clamp(Vector3D.Dot(current.Up, temp), -1, 1);
            double rollAngle = Math.Acos(dot);
            double scaler = ScalerProjection(temp, current.Right);
            if (scaler > 0)
                rollAngle *= -1;
            error.Z = rollAngle;
        }

        if (Math.Abs(error.X) < 0.001) error.X = 0;
        if (Math.Abs(error.Y) < 0.001) error.Y = 0;
        if (Math.Abs(error.Z) < 0.001) error.Z = 0;

        return error;
    }

    public void FaceVectors (Vector3D forward, Vector3D up)
    {
        Vector3D error = -GetAngles(rc.WorldMatrix, forward, up);
        Vector3D angles = new Vector3D(anglePID.Control(error));
        ApplyFineDamping(error, ref angles);
        ApplyGyroOverride(rc.WorldMatrix, angles);
    }

    void ApplyFineDamping(Vector3D error, ref Vector3D angles)
    {
        if (Math.Abs(error.X) < gyroErrorDeadbandRad) angles.X = 0;
        if (Math.Abs(error.Y) < gyroErrorDeadbandRad) angles.Y = 0;
        if (Math.Abs(error.Z) < gyroErrorDeadbandRad) angles.Z = 0;

        double errMag = error.Length();
        if (errMag < gyroFineDampRangeRad)
        {
            double s = MathHelper.Clamp(errMag / gyroFineDampRangeRad, 0.2, 1.0);
            angles *= s;
        }

        if (Math.Abs(angles.X) < gyroOutputDeadband) angles.X = 0;
        if (Math.Abs(angles.Y) < gyroOutputDeadband) angles.Y = 0;
        if (Math.Abs(angles.Z) < gyroOutputDeadband) angles.Z = 0;

        angles.X = MathHelper.Clamp(angles.X, -gyroRateLimit, gyroRateLimit);
        angles.Y = MathHelper.Clamp(angles.Y, -gyroRateLimit, gyroRateLimit);
        angles.Z = MathHelper.Clamp(angles.Z, -gyroRateLimit, gyroRateLimit);
    }

    void ApplyGyroOverride (MatrixD current, Vector3D localAngles)
    {
        Vector3D worldAngles = Vector3D.TransformNormal(localAngles, current);
        foreach (IMyGyro gyro in gyros)
        {
            Vector3D transVect = Vector3D.TransformNormal(worldAngles, MatrixD.Transpose(gyro.WorldMatrix));
            gyro.Pitch = (float)transVect.X;
            gyro.Yaw = (float)transVect.Y;
            gyro.Roll = (float)transVect.Z;
            gyro.GyroOverride = true;
        }
    }

    public static double ScalerProjection (Vector3D value, Vector3D guide)
    {
        double returnValue = Vector3D.Dot(value, guide);
        if (double.IsNaN(returnValue))
            return 0;
        return returnValue;
    }

    public static Vector3D VectorPojection (Vector3D value, Vector3D guide)
    {
        return ScalerProjection(value, guide) * guide;
    }

    public static Vector3D VectorRejection (Vector3D value, Vector3D guide)
    {
        return value - VectorPojection(value, guide);
    }
}

public class PID
{
    double _kP = 0;
    double _kI = 0;
    double _kD = 0;
    double _integralDecayRatio = 0;
    double _lowerBound = 0;
    double _upperBound = 0;
    double _timeStep = 0;
    double _inverseTimeStep = 0;
    double _errorSum = 0;
    double _lastError = 0;
    bool _firstRun = true;
    bool _integralDecay = false;
    public double Value { get; private set; }

    public PID (double kP, double kI, double kD, double lowerBound, double upperBound, double timeStep)
    {
        _kP = kP; _kI = kI; _kD = kD;
        _lowerBound = lowerBound; _upperBound = upperBound;
        _timeStep = timeStep; _inverseTimeStep = 1 / _timeStep;
        _integralDecay = false;
    }

    public PID (double kP, double kI, double kD, double integralDecayRatio, double timeStep)
    {
        _kP = kP; _kI = kI; _kD = kD;
        _timeStep = timeStep; _inverseTimeStep = 1 / _timeStep;
        _integralDecayRatio = integralDecayRatio;
        _integralDecay = true;
    }

    public double Control (double error)
    {
        var errorDerivative = (error - _lastError) * _inverseTimeStep;
        if (_firstRun)
        {
            errorDerivative = 0;
            _firstRun = false;
        }

        if (!_integralDecay)
        {
            _errorSum += error * _timeStep;
            if (_errorSum > _upperBound) _errorSum = _upperBound;
            else if (_errorSum < _lowerBound) _errorSum = _lowerBound;
        }
        else
        {
            _errorSum = _errorSum * (1.0 - _integralDecayRatio) + error * _timeStep;
        }

        _lastError = error;
        this.Value = _kP * error + _kI * _errorSum + _kD * errorDerivative;
        return this.Value;
    }

    public void Reset ()
    {
        _errorSum = 0;
        _lastError = 0;
        _firstRun = true;
    }
}

public class VectorPID
{
    private PID X;
    private PID Y;
    private PID Z;

    public VectorPID (double kP, double kI, double kD, double lowerBound, double upperBound, double timeStep)
    {
        X = new PID(kP, kI, kD, lowerBound, upperBound, timeStep);
        Y = new PID(kP, kI, kD, lowerBound, upperBound, timeStep);
        Z = new PID(kP, kI, kD, lowerBound, upperBound, timeStep);
    }

    public VectorPID (double kP, double kI, double kD, double integralDecayRatio, double timeStep)
    {
        X = new PID(kP, kI, kD, integralDecayRatio, timeStep);
        Y = new PID(kP, kI, kD, integralDecayRatio, timeStep);
        Z = new PID(kP, kI, kD, integralDecayRatio, timeStep);
    }

    public Vector3D Control (Vector3D error)
    {
        return new Vector3D(X.Control(error.X), Y.Control(error.Y), Z.Control(error.Z));
    }

    public void Reset ()
    {
        X.Reset(); Y.Reset(); Z.Reset();
    }
}

const double thrustP = 3;
const double thrustI = 2;
const double thrustD = 2;
const double thrustDecay = 0.2;
const float minThrust = 1.0000001f;

class ThrusterControl
{
    private List<IMyThrust> thrusters = new List<IMyThrust>();
    IMyShipController rc;
    VectorPID pid;

    public void Reset ()
    {
        foreach (IMyThrust t in thrusters)
            t.ThrustOverride = 0;
    }

    public ThrusterControl (IMyShipController rc, UpdateFrequency tickSpeed, List<IMyThrust> thrusters)
    {
        if (rc == null)
            throw new Exception("Ship controller null.");

        double factor = 1;
        if (tickSpeed == UpdateFrequency.Update10)
            factor = 10;
        else if (tickSpeed == UpdateFrequency.Update100)
            factor = 100;
        double secondsPerTick = (1.0 / 60) * factor;

        pid = new VectorPID(thrustP / factor, thrustI / factor, thrustD / factor, thrustDecay / factor, secondsPerTick);
        this.rc = rc;
        this.thrusters = thrusters;
        Reset();
    }

    public Vector3D ControlPosition (Vector3D targetPosition, Vector3D targetVelocity, double maxSpeed = double.PositiveInfinity)
    {
        return ControlVelocity(targetVelocity + VectorClamp(-pid.Control(rc.GetPosition() - targetPosition), maxSpeed));
    }

    public Vector3D VectorClamp (Vector3D v, double max)
    {
        double len2 = v.LengthSquared();
        if (len2 > max * max)
            v = (v / Math.Sqrt(len2)) * max;
        return v;
    }

    public Vector3D ControlVelocity (Vector3D targetVelocity)
    {
        Vector3D myVel = rc.GetShipVelocities().LinearVelocity;
        Vector3D deltaV = myVel - targetVelocity;
        if (Vector3D.IsZero(deltaV))
            return Vector3D.Zero;

        Vector3D gravity = rc.GetNaturalGravity();
        return 2 * deltaV + gravity;
    }

    public void ApplyAccel (Vector3D accel)
    {
        if (accel.Equals(Vector3D.Zero, 0.1))
            accel = Vector3D.Zero;

        Vector3D thrust = accel * rc.CalculateShipMass().TotalMass;
        foreach (IMyThrust t in thrusters)
        {
            if (!t.IsFunctional)
                continue;

            float outputThrust = (float)Vector3D.Dot(t.WorldMatrix.Forward, thrust);
            if (outputThrust > 0)
            {
                float outputProportion = MathHelper.Clamp(outputThrust / t.MaxEffectiveThrust, minThrust / t.MaxThrust, 1);
                t.ThrustOverridePercentage = outputProportion;
                thrust -= t.WorldMatrix.Forward * outputProportion * t.MaxEffectiveThrust;
            }
            else
            {
                t.ThrustOverride = minThrust;
            }
        }
    }
}
